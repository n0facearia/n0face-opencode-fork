#!/bin/sh
set -e
# Capture pre-push ref info from stdin before any other command
read local_ref local_sha remote_ref remote_sha 2>/dev/null || true
# Check if bun version matches package.json
# keep in sync with packages/script/src/index.ts semver qualifier
bun -e '
import { semver } from "bun";
const pkg = await Bun.file("package.json").json();
const expectedBunVersion = pkg.packageManager?.split("@")[1];
if (!expectedBunVersion) {
  throw new Error("packageManager field not found in root package.json");
}
const expectedBunVersionRange = `^${expectedBunVersion}`;
if (!semver.satisfies(process.versions.bun, expectedBunVersionRange)) {
  throw new Error(`This script requires bun@${expectedBunVersionRange}, but you are using bun@${process.versions.bun}`);
}
if (process.versions.bun !== expectedBunVersion) {
  console.warn(`Warning: Bun version ${process.versions.bun} differs from expected ${expectedBunVersion}`);
}
'
# Scope typecheck to packages with changes since the remote ref,
# avoiding pre-existing errors in untouched packages (app, desktop, llm, ui).
if [ -z "$remote_sha" ] || [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
  exec bun typecheck
fi

changed_packages=$(git diff --name-only "$remote_sha" | grep '^packages/' | while read -r f; do d=$(dirname "$f"); while [ "$d" != "." ] && [ ! -f "$d/package.json" ]; do d=$(dirname "$d"); done; [ -f "$d/package.json" ] && echo "$d"; done | sort -u)

if [ -z "$changed_packages" ]; then
  exit 0
fi

filters=""
for pkg in $changed_packages; do
  filters="$filters --filter=./$pkg"
done

exec bun turbo typecheck $filters
